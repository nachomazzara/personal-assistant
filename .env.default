# =============================================================================
# Personal Assistant — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Server ---
# PORT (optional) — HTTP server port, defaults to 3000
PORT=3000

# --- Authentication ---
# ANTHROPIC_OAUTH_REFRESH_TOKEN (required if no .auth.json) — Used by the LLM
# router, grouper, and video prompt generator. If you have a .auth.json file
# in the project root with your Anthropic credentials, this is not needed.
ANTHROPIC_OAUTH_REFRESH_TOKEN=

# --- Twitter / X ---
# TWITTER_USER (required for twitter provider) — Email or username for X auto-login
TWITTER_USER=
# TWITTER_PASS (required for twitter provider) — Password for X auto-login
TWITTER_PASS=

# --- YouTube ---
# YOUTUBE_API_KEY (required for youtube provider) — YouTube Data API v3 key
# Get one at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# --- TikTok ---
# TIKTOK_USER (optional) — Email/username for TikTok login via Puppeteer
# Without credentials, falls back to public API (hashtag stats only, no video data)
TIKTOK_USER=
# TIKTOK_PASS (optional) — Password for TikTok login
TIKTOK_PASS=
