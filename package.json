{
  "name": "personal-assistant",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "agent": "tsx agent.ts",
    "build:web": "esbuild web/app.ts --bundle --outfile=web/dist/app.js --format=esm",
    "watch:web": "esbuild web/app.ts --bundle --outfile=web/dist/app.js --format=esm --watch",
    "start": "tsx server.ts",
    "dev": "npm run build:web && npm run watch:web & tsx --watch server.ts"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rebrowser-puppeteer": "^24.8.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
